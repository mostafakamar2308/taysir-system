generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  academyName   String
  academySize   String?
  currentMethod String?
  reviewBonus   Boolean  @default(false)
  videoBonus    Boolean  @default(false)
  terms         Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([academySize])
  @@index([id])
}

// ===================General Data=================

model Speciality {
  id    Int    @id @default(autoincrement())
  title String

  tutor Tutor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Currency {
  id Int @id @default(autoincrement())

  code   String @unique // ISO code: USD, SAR, EGP 
  name   String // US Dollar, Saudi Riyal, Egyptian Pound
  symbol String // $, ﷼, £

  students  Student[]
  tutors    Tutor[]
  payments  Revenue[]
  expenses  Expense[]
  academies Academy[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  plans                Plan[]
  academyCurrencyRates AcademyCurrencyRate[]

  @@index([code])
}

model SaasPlan {
  id            Int       @id @default(autoincrement())
  name          String
  dollarPrice   Float
  egyptianPrice Float
  maxStudents   Int
  maxTutors     Int
  billingPeriod Int
  features      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  academies     Academy[]
}

// ===================Academy Data=================

model Academy {
  id                Int       @id @default(autoincrement())
  name              String
  maxTutors         Int
  maxStudents       Int
  primaryColor      String
  defaultCurrencyId Int?
  defaultCurrency   Currency? @relation(fields: [defaultCurrencyId], references: [id])
  saasPlan          SaasPlan? @relation(fields: [saasPlanId], references: [id])
  saasPlanId        Int?
  saasPlanStartDate DateTime?
  saasPlanEndDate   DateTime?

  whatsappInstanceName     String?   @unique
  whatsappInstanceToken    String?
  whatsappConnectionStatus String?   @default("disconnected")
  whatsappConnectedAt      DateTime?
  whatsappDisconnectedAt   DateTime?
  whatsappWebhookUrl       String?

  admin                Admin?
  adminId              Int?
  supervisors          Supervisor[]
  tutors               Tutor[]
  students             Student[]
  sessions             Session[]
  expenses             Expense[]
  plans                Plan[]
  histories            History[]
  revenues             Revenue[]
  academyCurrencyRates AcademyCurrencyRate[]
  whatsAppMessages     WhatsAppMessage[]
  subscriptions        Subscription[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  chatRooms ChatRoom[]
}

model AcademyCurrencyRate {
  id         Int      @id @default(autoincrement())
  academyId  Int
  academy    Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  currencyId Int
  currency   Currency @relation(fields: [currencyId], references: [id])
  rate       Float // conversion rate to academy's default currency (1 unit of this currency = rate units of default currency)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([academyId, currencyId])
  @@index([academyId])
}

// ===================USERS=================
model User {
  id                Int     @id @default(autoincrement())
  email             String  @unique
  password          String
  name              String?
  role              Int
  timezone          String  @default("Africa/Cairo")
  phone             String?
  preferredLanguage String  @default("ar")
  imageUrl          String?

  superAdmin       SuperAdmin?
  admin            Admin?
  supervisor       Supervisor?
  student          Student?
  tutor            Tutor?
  notes            Note[]
  revenues         Revenue[]
  expenses         Expense[]
  chatMessages     ChatMessage[]
  tutorChatRooms   ChatRoom[]    @relation("TutorChatRooms")
  studentChatRooms ChatRoom[]    @relation("StudentChatRooms")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int     @unique
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Student {
  id                    Int      @id @default(autoincrement())
  age                   Int      @default(12)
  country               String?
  status                Int      @default(0)
  currencyId            Int
  currency              Currency @relation(fields: [currencyId], references: [id])
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionsBalance       Int      @default(0)
  currentSubscriptionId Int?

  source                String?
  currentProgram        String?
  emergencyContactName  String?
  emergencyContactPhone String?

  tutorId Int?
  tutor   Tutor? @relation(fields: [tutorId], references: [id])

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  planId Int?
  plan   Plan? @relation(fields: [planId], references: [id])

  sessions              Session[]
  studentAvailabilities StudentAvailability[]
  notes                 Note[]
  payments              Revenue[]
  subscriptions         Subscription[]        @relation("StudentSubscriptions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorId])
  @@index([status])
}

model Supervisor {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Tutor {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId  Int
  academy    Academy  @relation(fields: [academyId], references: [id])
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId Int

  pricePerHour      Float
  active            Boolean?
  bio               String?
  qualifications    String?
  imageUrl          String?
  zoomAuthenticated Boolean   @default(false)
  zoomUrl           String?
  zoomAccessToken   String?
  zoomRefreshToken  String?
  zoomTokenExpiry   DateTime?
  zoomUserId        String?

  specialities        Speciality[]
  students            Student[]
  sessions            Session[]
  tutorAvailabilities TutorAvailability[]
  notes               Note[]
  expenses            Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model SuperAdmin {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ===================Plan and Subscriptions=================

model Plan {
  id              Int    @id @default(autoincrement())
  title           String
  sessionsPerWeek Int
  price           Float  @default(0)
  billingPeriod   Int    @default(30)

  currencyId Int
  currency   Currency  @relation(fields: [currencyId], references: [id])
  academyId  Int
  academy    Academy   @relation(fields: [academyId], references: [id])
  students   Student[]
  revenues   Revenue[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id        Int       @id @default(autoincrement())
  academyId Int
  academy   Academy   @relation(fields: [academyId], references: [id])
  studentId Int
  student   Student   @relation("StudentSubscriptions", fields: [studentId], references: [id])
  planId    Int
  plan      Plan      @relation(fields: [planId], references: [id])
  startDate DateTime
  endDate   DateTime?
  status    Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payments Revenue[]

  @@index([studentId])
  @@index([planId])
  @@index([status])
}

// ===================Session and Attendance=================

model Session {
  id              Int      @id @default(autoincrement())
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int      @default(60)
  topic           String?
  notes           String?
  isTrial         Boolean  @default(false)
  cancelledBy     Int?

  zoomMeetingId   String?
  zoomJoinUrl     String?
  zoomStartUrl    String?
  zoomMeetingUuid String?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  tutorId   Int
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  attendance    Attendance?
  sessionReport SessionReport?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([tutorId])
  @@index([isTrial])
}

model Attendance {
  id                      Int     @id @default(autoincrement())
  sessionId               Int     @unique
  session                 Session @relation(fields: [sessionId], references: [id])
  tutorAttendanceStatus   Int
  studentAttendanceStatus Int
  reason                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TutorAvailability {
  id        Int      @id @default(autoincrement())
  tutorId   Int
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentAvailability {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id         Int    @id @default(autoincrement())
  content    String
  targetType Int
  targetId   Int
  authorId   Int
  author     User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tutor     Tutor?   @relation(fields: [tutorId], references: [id])
  tutorId   Int?
  student   Student? @relation(fields: [studentId], references: [id])
  studentId Int?

  @@index([targetType, targetId])
  @@index([authorId])
}

model SessionReport {
  id        Int     @id @default(autoincrement())
  sessionId Int     @unique
  session   Session @relation(fields: [sessionId], references: [id])
  rating    Int? // 1-5

  outcomes   String?
  strengths  String?
  weaknesses String?
  nextGoals  String?
  comments   String?
  // Optional JSON for extra fields
  details    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}

// ===================Finances=================

model Revenue {
  id          Int      @id @default(autoincrement())
  amount      Float
  currencyId  Int
  currency    Currency @relation(fields: [currencyId], references: [id])
  status      Int      @default(0)
  method      Int?
  // Time to pay usually today.
  dueDate     DateTime @default(now())
  description String?
  channel     String?
  notes       String?
  invoiceUrl  String?

  academyId      Int
  academy        Academy       @relation(fields: [academyId], references: [id])
  studentId      Int
  student        Student       @relation(fields: [studentId], references: [id])
  planId         Int?
  plan           Plan?         @relation(fields: [planId], references: [id])
  recordedBy     Int?
  recorder       User?         @relation(fields: [recordedBy], references: [id])
  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  amount      Float
  currencyId  Int
  currency    Currency @relation(fields: [currencyId], references: [id])
  method      Int?
  status      Int      @default(0)
  invoiceUrl  String?
  notes       String?

  tutorId     Int?
  tutor       Tutor?  @relation(fields: [tutorId], references: [id])
  salaryMonth String?

  academyId    Int
  academy      Academy     @relation(fields: [academyId], references: [id])
  recordedBy   Int?
  user         User?       @relation(fields: [recordedBy], references: [id])
  costCenterId Int?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId])
  @@index([tutorId])
  @@index([date])
}

// ===================Meta Data=================

model History {
  id           Int     @id @default(autoincrement())
  targetType   Int
  targetId     Int
  action       Int
  changes      Json?
  metadata     Json?
  recordedBy   Int
  recorderType Int
  academyId    Int
  academy      Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([action])
  @@index([academyId])
}

model WhatsAppMessage {
  id           String    @id @default(cuid())
  academyId    Int
  academy      Academy   @relation(fields: [academyId], references: [id])
  messageId    String?
  remoteJid    String
  type         String // "text", "image", etc.
  content      String?
  status       String // "pending", "sent", "delivered", "read", "failed"
  sentAt       DateTime  @default(now())
  deliveredAt  DateTime?
  readAt       DateTime?
  errorMessage String?

  @@index([academyId])
}

model CostCenter {
  id    Int    @id @default(autoincrement())
  title String

  expenses Expense[]

  createdAt DateTime @default(now())
}

model ChatRoom {
  id            Int     @id @default(autoincrement())
  tutorUserId   Int
  tutor         User    @relation(fields: [tutorUserId], references: [id], name: "TutorChatRooms")
  studentUserId Int
  student       User    @relation(fields: [studentUserId], references: [id], name: "StudentChatRooms")
  isClosed      Boolean @default(false)
  academyId     Int
  academy       Academy @relation(fields: [academyId], references: [id])

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tutorUserId, studentUserId])
  @@index([tutorUserId, studentUserId])
  @@index([academyId])
}

model ChatMessage {
  id        Int       @id @default(autoincrement())
  roomId    Int
  room      ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User      @relation(fields: [senderId], references: [id])
  content   String
  isRead    Boolean   @default(false)
  isDeleted Boolean   @default(false)
  readAt    DateTime?
  refId     String? // client‑side temporary ID for optimistic updates

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([senderId])
}
