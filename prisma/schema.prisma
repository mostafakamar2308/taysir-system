generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  academyName   String
  academySize   String?
  currentMethod String?
  reviewBonus   Boolean  @default(false)
  videoBonus    Boolean  @default(false)
  terms         Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([academySize])
  @@index([id])
}

model User {
  id                Int     @id @default(autoincrement())
  email             String  @unique
  password          String
  name              String?
  role              Int
  timezone          String  @default("Africa/Cairo")
  phone             String?
  preferredLanguage String  @default("ar")

  superAdmin SuperAdmin?
  admin      Admin?
  supervisor Supervisor?
  tutor      Tutor?
  notes      Note[]
  revenues   Revenue[]
  reports    Report[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Academy {
  id                Int       @id @default(autoincrement())
  name              String
  maxTutors         Int
  maxStudents       Int
  primaryColor      String
  defaultCurrencyId Int?
  defaultCurrency   Currency? @relation(fields: [defaultCurrencyId], references: [id])
  saasPlan          SaasPlan? @relation(fields: [saasPlanId], references: [id])
  saasPlanId        Int?
  saasPlanStartDate DateTime?
  saasPlanEndDate   DateTime?

  admin                Admin?
  adminId              Int?
  supervisors          Supervisor[]
  tutors               Tutor[]
  students             Student[]
  sessions             Session[]
  recurringPatterns    RecurringPattern[]
  expenses             Expense[]
  reports              Report[]
  plans                Plan[]
  histories            History[]
  revenues             Revenue[]
  academyCurrencyRates AcademyCurrencyRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int     @unique
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Student {
  id         Int      @id @default(autoincrement())
  name       String
  email      String?
  age        Int      @default(12)
  phone      String?
  country    String?
  timezone   String
  status     Int      @default(0)
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId Int

  source                String?
  currentProgram        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  preferredLanguage     String?
  imageUrl              String?
  currentSubscriptionId Int?

  tutorId Int?
  tutor   Tutor? @relation(fields: [tutorId], references: [id])

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  planId Int?
  plan   Plan? @relation(fields: [planId], references: [id])

  sessions              Session[]
  recurringPatterns     RecurringPattern[]
  studentAvailabilities StudentAvailability[]
  notes                 Note[]
  payments              Revenue[]
  subscriptions         Subscription[]        @relation("StudentSubscriptions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorId])
  @@index([status])
}

model Supervisor {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Tutor {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId  Int
  academy    Academy  @relation(fields: [academyId], references: [id])
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId Int

  pricePerSession   Float
  active            Boolean?
  bio               String?
  qualifications    String?
  imageUrl          String?
  zoomAuthenticated Boolean  @default(false)
  zoomUrl           String?

  specialities        Speciality[]
  students            Student[]
  sessions            Session[]
  recurringPatterns   RecurringPattern[]
  tutorAvailabilities TutorAvailability[]
  notes               Note[]
  expenses            Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Plan {
  id              Int    @id @default(autoincrement())
  title           String
  sessionsPerWeek Int
  price           Float  @default(0)
  billingPeriod   Int    @default(30)

  currencyId Int
  currency   Currency  @relation(fields: [currencyId], references: [id])
  academyId  Int
  academy    Academy   @relation(fields: [academyId], references: [id])
  students   Student[]
  revenues   Revenue[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Session {
  id              Int      @id @default(autoincrement())
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int      @default(60)
  topic           String?
  notes           String?
  isTrial         Boolean  @default(false)
  cancelledBy     Int?

  studentId          Int
  student            Student           @relation(fields: [studentId], references: [id])
  tutorId            Int
  tutor              Tutor             @relation(fields: [tutorId], references: [id])
  academyId          Int
  academy            Academy           @relation(fields: [academyId], references: [id])
  recurringPatternId Int?
  recurringPattern   RecurringPattern? @relation(fields: [recurringPatternId], references: [id])

  attendance    Attendance?
  sessionReport SessionReport?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([tutorId])
  @@index([isTrial])
}

model RecurringPattern {
  id              Int       @id @default(autoincrement())
  daysOfWeek      Int[]
  startTime       DateTime
  durationMinutes Int
  startDate       DateTime
  endDate         DateTime?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  tutorId   Int
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id                      Int     @id @default(autoincrement())
  sessionId               Int     @unique
  session                 Session @relation(fields: [sessionId], references: [id])
  tutorAttendanceStatus   Int
  studentAttendanceStatus Int
  reason                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TutorAvailability {
  id        Int      @id @default(autoincrement())
  tutorId   Int
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentAvailability {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id         Int    @id @default(autoincrement())
  content    String
  targetType Int
  targetId   Int
  authorId   Int
  author     User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tutor     Tutor?   @relation(fields: [tutorId], references: [id])
  tutorId   Int?
  student   Student? @relation(fields: [studentId], references: [id])
  studentId Int?

  @@index([targetType, targetId])
  @@index([authorId])
}

model Revenue {
  id          Int       @id @default(autoincrement())
  amount      Float
  currencyId  Int
  currency    Currency  @relation(fields: [currencyId], references: [id])
  status      Int       @default(0)
  method      Int?
  date        DateTime  @default(now())
  dueDate     DateTime?
  description String? // e.g., "Monthly subscription March 2026"
  channel     String?
  notes       String?
  invoiceUrl  String?

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  studentId  Int
  student    Student @relation(fields: [studentId], references: [id])
  planId     Int?
  plan       Plan?   @relation(fields: [planId], references: [id])
  recordedBy Int?
  recorder   User?   @relation(fields: [recordedBy], references: [id])

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([studentId])
  @@index([status])
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  costCenter  String?
  amount      Float
  currencyId  Int
  currency    Currency @relation(fields: [currencyId], references: [id])
  method      Int?
  status      Int      @default(0)
  invoiceUrl  String?
  notes       String?

  tutorId     Int?
  tutor       Tutor?  @relation(fields: [tutorId], references: [id])
  salaryMonth String?

  academyId  Int
  academy    Academy @relation(fields: [academyId], references: [id])
  recordedBy Int?
  user       User?   @relation(fields: [recordedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId])
  @@index([tutorId])
  @@index([date])
}

model SessionReport {
  id        Int     @id @default(autoincrement())
  sessionId Int     @unique
  session   Session @relation(fields: [sessionId], references: [id])
  rating    Int? // 1-5

  outcomes   String?
  strengths  String?
  weaknesses String?
  nextGoals  String?
  comments   String?
  // Optional JSON for extra fields
  details    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  type        String // "student_progress", "tutor_performance", "financial"
  month       String // YYYY-MM
  generatedAt DateTime @default(now())
  fileUrl     String? // URL to the generated file (PDF, CSV)
  createdBy   Int? // User.id
  user        User?    @relation(fields: [createdBy], references: [id])
  academyId   Int
  academy     Academy  @relation(fields: [academyId], references: [id])

  @@index([academyId])
  @@index([type])
  @@index([month])
}

model Speciality {
  id    Int    @id @default(autoincrement())
  title String

  tutor Tutor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Currency {
  id Int @id @default(autoincrement())

  code   String @unique // ISO code: USD, SAR, EGP 
  name   String // US Dollar, Saudi Riyal, Egyptian Pound
  symbol String // $, ﷼, £

  students  Student[]
  tutors    Tutor[]
  payments  Revenue[]
  expenses  Expense[]
  academies Academy[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  plans                Plan[]
  academyCurrencyRates AcademyCurrencyRate[]

  @@index([code])
}

model SuperAdmin {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Subscription {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation("StudentSubscriptions", fields: [studentId], references: [id])
  planId    Int
  plan      Plan      @relation(fields: [planId], references: [id])
  startDate DateTime
  endDate   DateTime?
  status    Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payments Revenue[]

  @@index([studentId])
  @@index([planId])
  @@index([status])
}

model History {
  id           Int     @id @default(autoincrement())
  targetType   Int
  targetId     Int
  action       Int
  changes      Json?
  metadata     Json?
  recordedBy   Int
  recorderType Int
  academyId    Int
  academy      Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([action])
  @@index([academyId])
}

model AcademyCurrencyRate {
  id         Int      @id @default(autoincrement())
  academyId  Int
  academy    Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  currencyId Int
  currency   Currency @relation(fields: [currencyId], references: [id])
  rate       Float // conversion rate to academy's default currency (1 unit of this currency = rate units of default currency)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([academyId, currencyId])
  @@index([academyId])
}

model SaasPlan {
  id            Int       @id @default(autoincrement())
  name          String
  dollarPrice   Float
  egyptianPrice Float
  maxStudents   Int
  maxTutors     Int
  billingPeriod Int
  features      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  academies     Academy[]
}
