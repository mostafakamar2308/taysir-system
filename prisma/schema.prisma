generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  academyName   String
  academySize   String?
  currentMethod String?
  reviewBonus   Boolean  @default(false)
  videoBonus    Boolean  @default(false)
  terms         Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([academySize])
  @@index([id])
}

model Academy {
  id   Int    @id @default(autoincrement())
  name String

  admin       Admin?
  supervisors Supervisor[]
  tutors      Tutor[]
  students    Student[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  recurringPatterns RecurringPattern[]
  expenses          Expense[]
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
  role     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timezone String @default("Africa/Cairo")

  superAdmin SuperAdmin?
  admin      Admin?
  supervisor Supervisor?
  tutor      Tutor?
  notes      Note[]
  payments   Payment[]
}

model SuperAdmin {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Admin {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int     @unique
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  age         Int       @default(12)
  phone       String?
  country     String?
  timezone    String
  status      Int       @default(0)
  startDate   DateTime  @default(now())
  renewalDate DateTime?

  source                String? // e.g., "facebook", "snapchat", "referral"
  currentProgram        String? // e.g., "Quran Memorization", "Tajweed"
  emergencyContactName  String?
  emergencyContactPhone String?
  preferredLanguage     String? // e.g., "ar", "en"
  profilePicture        String?

  tutorId Int?
  tutor   Tutor? @relation(fields: [tutorId], references: [id])

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  planId Int?
  plan   Plan? @relation(fields: [planId], references: [id])

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  sessions              Session[]
  recurringPatterns     RecurringPattern[]
  studentAvailabilities StudentAvailability[]
  notes                 Note[]
  payments              Payment[]
}

model Supervisor {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Tutor {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  pricePerSession Float
  specialities    Speciality[]
  active          Boolean?

  phone             String
  bio               String? // short description
  qualifications    String? // text, could be JSON or simple string
  profilePicture    String? // URL
  maxStudents       Int?
  zoomAuthenticated Boolean @default(false)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  students            Student[]
  sessions            Session[]
  recurringPatterns   RecurringPattern[]
  tutorAvailabilities TutorAvailability[]
  notes               Note[]
  expenses            Expense[]

  @@index([userId])
}

model Speciality {
  id    Int    @id @default(autoincrement())
  title String

  tutor Tutor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id              Int    @id @default(autoincrement())
  title           String
  sessionsPerWeek Int
  price           Float  @default(0)
  billingPeriod   String @default("monthly")

  students Student[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
}

model Session {
  id              Int      @id @default(autoincrement())
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  status          Int      @default(0)
  topic           String?
  notes           String?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  tutorId   Int
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  recurringPatternId Int?
  recurringPattern   RecurringPattern? @relation(fields: [recurringPatternId], references: [id])

  attendance Attendance?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessionReport SessionReport?
}

model RecurringPattern {
  id              Int       @id @default(autoincrement())
  daysOfWeek      Int[]
  startTime       DateTime
  durationMinutes Int
  startDate       DateTime
  endDate         DateTime?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  tutorId   Int
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id              Int      @id @default(autoincrement())
  sessionId       Int      @unique
  session         Session  @relation(fields: [sessionId], references: [id])
  status          Int
  reason          String?
  madeUpSessionId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TutorAvailability {
  id        Int      @id @default(autoincrement())
  tutorId   Int
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tutorId, dayOfWeek, startTime])
}

model StudentAvailability {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id         Int    @id @default(autoincrement())
  content    String
  targetType Int
  targetId   Int // ID of the target (Student.id or Tutor.id)
  authorId   String // User.id who wrote the note
  author     User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tutor     Tutor?   @relation(fields: [tutorId], references: [id])
  tutorId   Int?
  student   Student? @relation(fields: [studentId], references: [id])
  studentId Int?

  @@index([targetType, targetId])
  @@index([authorId])
}

model Payment {
  id          Int       @id @default(autoincrement())
  amount      Float
  currency    String    @default("EGP") // or whatever
  status      Int       @default(0)
  method      Int?
  date        DateTime  @default(now())
  dueDate     DateTime? // for invoices
  description String? // e.g., "Monthly subscription March 2026"
  channel     String? // القناة (optional)
  notes       String? // ملاحظات

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  // Optional link to a plan
  planId Int?
  plan   Plan? @relation(fields: [planId], references: [id])

  // Who recorded/confirmed the payment
  recordedBy String? // User.id
  recorder   User?   @relation(fields: [recordedBy], references: [id])

  invoiceUrl String? // link to PDF or external invoice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model Expense {
  id            Int      @id @default(autoincrement())
  date          DateTime
  description   String
  costCenter    String? // e.g., "رواتب", "إيجار", "تسويق"
  amount        Float
  currency      String   @default("EGP")
  paymentMethod Int? // reuse same enum as Payment.method (0=CASH,1=CARD,2=BANK_TRANSFER,3=ONLINE)
  paid          Boolean  @default(false)
  reference     String? // receipt number, invoice link
  notes         String?

  // For tutor salaries
  tutorId     Int?
  tutor       Tutor?  @relation(fields: [tutorId], references: [id])
  salaryMonth String? // format: YYYY-MM

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId])
  @@index([tutorId])
  @@index([date])
}

model SessionReport {
  id        Int     @id @default(autoincrement())
  sessionId Int     @unique
  session   Session @relation(fields: [sessionId], references: [id])

  memorization String?
  revision     String?
  tajweed      String?
  strengths    String?
  weaknesses   String?
  nextGoals    String?
  // Optional JSON for extra fields
  details      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}
