generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  academyName   String
  academySize   String?
  currentMethod String?
  reviewBonus   Boolean  @default(false)
  videoBonus    Boolean  @default(false)
  terms         Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([academySize])
  @@index([id])
}

model Academy {
  id   Int    @id @default(autoincrement())
  name String

  admin       Admin?
  supervisors Supervisor[]
  tutors      Tutor[]
  students    Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
  role     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  superAdmin SuperAdmin?
  admin      Admin?
  supervisor Supervisor?
  tutor      Tutor?
}

model SuperAdmin {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Admin {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int     @unique
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  country     String?
  timezone    String
  status      Int       @default(0)
  startDate   DateTime  @default(now())
  renewalDate DateTime?

  tutorId Int?
  tutor   Tutor? @relation(fields: [tutorId], references: [id])

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supervisor {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Tutor {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  pricePerSession Float
  specialities    Speciality[]
  active          Boolean?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  students  Student[]

  @@index([userId])
}

model Speciality {
  id    Int    @id @default(autoincrement())
  title String

  tutor Tutor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id              Int    @id @default(autoincrement())
  title           String
  sessionsPerWeek Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
