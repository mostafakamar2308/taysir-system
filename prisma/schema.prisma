generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  academyName   String
  academySize   String?
  currentMethod String?
  reviewBonus   Boolean  @default(false)
  videoBonus    Boolean  @default(false)
  terms         Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([academySize])
  @@index([id])
}

model Academy {
  id   Int    @id @default(autoincrement())
  name String

  admin       Admin?
  supervisors Supervisor[]
  tutors      Tutor[]
  students    Student[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  recurringPatterns RecurringPattern[]
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
  role     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timezone String @default("Africa/Cairo")

  superAdmin SuperAdmin?
  admin      Admin?
  supervisor Supervisor?
  tutor      Tutor?
}

model SuperAdmin {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Admin {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int     @unique
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  age         Int       @default(12)
  phone       String?
  country     String?
  timezone    String
  status      Int       @default(0)
  startDate   DateTime  @default(now())
  renewalDate DateTime?

  tutorId Int?
  tutor   Tutor? @relation(fields: [tutorId], references: [id])

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  planId Int?
  plan   Plan? @relation(fields: [planId], references: [id])

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  sessions              Session[]
  recurringPatterns     RecurringPattern[]
  studentAvailabilities StudentAvailability[]
}

model Supervisor {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Tutor {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  pricePerSession Float
  specialities    Speciality[]
  active          Boolean?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  students            Student[]
  sessions            Session[]
  recurringPatterns   RecurringPattern[]
  tutorAvailabilities TutorAvailability[]

  @@index([userId])
}

model Speciality {
  id    Int    @id @default(autoincrement())
  title String

  tutor Tutor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id              Int    @id @default(autoincrement())
  title           String
  sessionsPerWeek Int

  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id              Int      @id @default(autoincrement())
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  status          Int      @default(0)
  topic           String?
  notes           String?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  tutorId   Int
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  recurringPatternId Int?
  recurringPattern   RecurringPattern? @relation(fields: [recurringPatternId], references: [id])

  attendance Attendance?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecurringPattern {
  id              Int       @id @default(autoincrement())
  daysOfWeek      Int[]
  startTime       DateTime
  durationMinutes Int
  startDate       DateTime
  endDate         DateTime?

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  tutorId   Int
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  academyId Int
  academy   Academy @relation(fields: [academyId], references: [id])

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id              Int      @id @default(autoincrement())
  sessionId       Int      @unique
  session         Session  @relation(fields: [sessionId], references: [id])
  status          Int
  reason          String?
  madeUpSessionId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TutorAvailability {
  id        Int      @id @default(autoincrement())
  tutorId   Int
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tutorId, dayOfWeek, startTime])
}

model StudentAvailability {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
