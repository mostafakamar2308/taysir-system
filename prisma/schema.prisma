// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}

model Waitlist {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  academyName   String
  academySize   String? // e.g., "small", "medium", "large"
  currentMethod String? // e.g., "excel", "paper", "software"
  reviewBonus   Boolean  @default(false)
  videoBonus    Boolean  @default(false)
  terms         Boolean // must be true for valid submission
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([academySize])
  @@index([id])
}
